{
  "name": "prime-tickets-backend",
  "version": "1.0.0",
  "description": "Backend API for Prime Tickets Event Booking Application",
  "main": "server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "dev:watch": "cross-env NODE_ENV=development nodemon --watch routes --watch controllers --watch models --watch middleware --watch utils server.js",
    "prod": "cross-env NODE_ENV=production node server.js",
    "seed": "cross-env node seeders/index.js",
    "seed:admin": "cross-env node seeders/adminSeeder.js",
    "seed:full": "cross-env node seeders/fullSeeder.js",
    "seed:full:clear": "cross-env node seeders/fullSeeder.js --clear",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "event",
    "tickets",
    "booking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dot-env": "^0.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "mongoose-paginate-v2": "^1.9.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "twilio": "^5.11.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
